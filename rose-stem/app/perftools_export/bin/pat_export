#!/bin/bash

# -e  Exit immediately if a command exits with a non-zero status.
set -e

echo "#####################################################################"
echo "STARTING PERFTOOLS EXPORT"
echo "#####################################################################"

# $CYLC_TASK_WORK_DIR for `perftools-export_<task>`
MYPWD=$(pwd)
# $CYLC_TASK_WORK_DIR for `<task>` of `perftools-export_<task>`
PREVIOUS_WORKING_DIR=$MYPWD"/../"$PREVIOUS_JOB

# Find all directories that have "+pat" in their name
# e.g. xios_server.exe+pat+123935-1758t, lfric_atm+pat+123935-1758t
PAT_REPORTS=$(ls -t ${PREVIOUS_WORKING_DIR} | grep --line-buffered "+pat+")

echo "Found ${#PAT_REPORTS[@]} perftools output(s):"
echo "${PAT_REPORTS}"

# Loop over reports and generate ouput
for REPORT in "${PAT_REPORTS[@]}"
do
    # Report is found in PREVIOUS_WORKING_DIR
    PAT_REPORT_TARGET=$PREVIOUS_WORKING_DIR"/"$REPORT

    # Split the perftools output name into component parts, sep='+'
    IFS='+' read -r -a components <<< "$REPORT"
    # Get app name from split name
    APP_NAME=${components[0]}

    echo "#####################################################################"
    echo "Perftools Profile ${REPORT} found by export"
    echo "#####################################################################"

    pat_report $PAT_REPORT_TARGET

    echo "#####################################################################"
    echo "A basic pat_report has been run on the file "
    echo "${APP_NAME} executable can be removed without invalidating the report"
    echo "#####################################################################"

    DATEVAR=$(date +"%d-%m-%y-%H%M%S")
    FILETYPE=".txt"
    # Destinations for reports
    PAT_REPORT_NAMED=$APP_NAME"+pat+_"$DATEVAR$FILETYPE
    PAT_REPORT_NAMED_MPI=$APP_NAME"+pat+mpi_"$DATEVAR$FILETYPE

    pat_report -v -o $PAT_REPORT_NAMED $PAT_REPORT_TARGET

    echo "#####################################################################"
    echo "Output generated by pat_report has been saved in "$PAT_REPORT_NAMED
    echo "#####################################################################"

    pat_report -P -v -o $PAT_REPORT_NAMED_MPI $PAT_REPORT_TARGET

    echo "#####################################################################"
    echo "Ouput with MPI generated by pat_report has been saved in \
    "$PAT_REPORT_NAMED_MPI
    echo "#####################################################################"

    pat_report -P -O $RANK_REORDER_TYPE $PAT_REPORT_TARGET

    echo "#####################################################################"
    echo "MPICH_RANK_REORDER file generated"
    echo "#####################################################################"

    if ($OUTPUT_TO_DATADIR); then

        if [ "$ALTERNATE_OUTPUT_PATH" != " " -a "$ALTERNATE_OUTPUT_PATH" != "" ] ; then
            MOVE_OUTPUTS_TO=$ALTERNATE_OUTPUT_PATH"/"$APP_CONFIGURATION_OUTPUT"/"
        else
            MOVE_OUTPUTS_TO=$DATADIR"/"$OUTPUT_TOP_DIR_NAME"/"$APP_CONFIGURATION_OUTPUT"/"
        fi

        echo $MOVE_OUTPUTS_TO
        mkdir -p $MOVE_OUTPUTS_TO
        mv $PAT_REPORT_TARGET $MOVE_OUTPUTS_TO
        mv $PAT_REPORT_NAMED $PAT_REPORT_NAMED_MPI $MOVE_OUTPUTS_TO

        echo "#####################################################################"
        echo "All exported reports have been moved to "$MOVE_OUTPUTS_TO
        echo "#####################################################################"

    else
        echo "#####################################################################"
        echo $TARGET" can be found in "$PREVIOUS_WORKING_DIR
        echo "and new exported reports in "$MYPWD
        echo "#####################################################################"
    fi
done
